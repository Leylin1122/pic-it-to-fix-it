# Copy to .env.local and fill in. Never commit .env.local.

# Google AI Studio — server-side only (get a key at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=
# Optional: if the default model 404s for your key/region, try e.g.:
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Firebase (client-safe keys only in NEXT_PUBLIC_*)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
